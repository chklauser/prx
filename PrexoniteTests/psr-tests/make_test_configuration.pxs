name make_test_configuration;

namespace prx.test.make_test_configuration
    import sys.*,
           sys.seq(to_list => all,skip,map, filter => where)
{

    function get_test_file_names(path,pattern)[import System::IO] =
        ::Directory.EnumerateFiles(path ?? ".", pattern ?? "*.test.pxs", ::SearchOption.AllDirectories)
        >> where(f => not (f.Contains(@"\\_2\\") or f.Contains("/_2/")));

    function under_test = "under_test";
    function test_dependencies = "test_dependencies";
    function create_config(testUnits, deps, testCases)
    {
        var s = new Structure;
        s.\("under_test") = testUnits;	// ~String:[String]
        s.\("deps") = deps;				// ~String:[String]
        s.\("test_cases") = testCases;  	// ~[String]
        return s;
    }

    function read_metadata(file_name)[import {Prexonite, Prexonite::Compiler}]
    {
        var eng = new ::Engine;
        var app = new ::Application("read_metadata");
        var ldr = new ::Loader(eng,app);

        print("Reading $file_name ...");
        try {
            ldr.LoadFromFile(file_name);
        } catch(var e) {
            //ignore
        }
        println("done. ");

        function extract_list(key){
            if(app.Meta.ContainsKey(key)){
                return app.Meta[key].List >> map(entry => {
    				if(entry.IsList){
    					entry = entry.List >> all;
    					if(entry.Count == 0)
    						return null;
    					return entry[0].Text:(entry >> skip(1) >> map(?.Text) >> all);
    				} else {
    					return entry.Text:[];
    				}
    			}) >> where(? is not null) >> all;
    		}
            else
                return [];
        }

        var deps = extract_list(test_dependencies);
        var testUnits = extract_list(under_test);

        var testCases = app.Functions >> where(f => f.Meta["test"].Switch) >> map(?.Id) >> all;

        dispose(eng,app,ldr);

        println("\t", testUnits, " using ", deps," ",testCases.Count," test cases");

        return new config(testUnits, deps, testCases);
    }

    function write_json_string(writer, value)[import System]
    {
        var backslash = ::Convert.ToChar(92);
        var quote = ::Convert.ToChar(34);
        writer.Write(quote);
        foreach(var character in value.ToCharArray)
        {
            var code = ::Convert.ToInt32(character);
            if(code == 34 or code == 92)
            {
                writer.Write(backslash);
                writer.Write(character);
            }
            else if(code == 8 or code == 9 or code == 10 or code == 12 or code == 13)
            {
                writer.Write(backslash);
                writer.Write(::Convert.ToChar(if(code == 8) 98
                    else if(code == 9) 116
                    else if(code == 10) 110
                    else if(code == 12) 102
                    else 114));
            }
            else if(code < 32)
            {
                writer.Write(backslash);
                writer.Write("u");
                writer.Write(code.ToString("x4"));
            }
            else
                writer.Write(character);
        }
        writer.Write(quote);
    }

    function write_property_name(writer, name)
    {
        write_json_string(writer, name);
        writer.Write(":");
    }

    function write_dependencies(writer, name, dependencies)
    {
        write_property_name(writer, name);
        writer.Write("[");
        var dependencySeparator = "";
        foreach(var dependency in dependencies)
        {
            writer.Write(dependencySeparator);
            dependencySeparator = ",";
            writer.Write("{");
            write_property_name(writer, "file");
            write_json_string(writer, dependency.Key);
            writer.Write(",");
            write_property_name(writer, "dependencies");
            writer.Write("[");
            var fileSeparator = "";
            foreach(var dependencyFile in dependency.Value)
            {
                writer.Write(fileSeparator);
                fileSeparator = ",";
                write_json_string(writer, dependencyFile);
            }
            writer.Write("]}");
        }
        writer.Write("]");
    }

    // write_config writes version 1 of the JSON test configuration.
    //  - writer, an object that behaves like a System.IO.TextWriter
    //  - config, [test_file_name:{under_test,deps,test_cases}]
    function write_config(writer, config)
    {
        writer.Write("{");
        write_property_name(writer, "version");
        writer.Write("1,");
        write_property_name(writer, "suites");
        writer.Write("[");
        var suiteSeparator = "";
        foreach(var kvp in config)
        {
            writer.Write(suiteSeparator);
            suiteSeparator = ",";
            writer.Write("{");
            write_property_name(writer, "file");
            write_json_string(writer, kvp.Key);
            writer.Write(",");
            write_dependencies(writer, "unitsUnderTest", kvp.Value.under_test);
            writer.Write(",");
            write_dependencies(writer, "testDependencies", kvp.Value.deps);
            writer.Write(",");
            write_property_name(writer, "tests");
            writer.Write("[");
            var testSeparator = "";
            foreach(var testCase in kvp.Value.test_cases)
            {
                writer.Write(testSeparator);
                testSeparator = ",";
                write_json_string(writer, testCase);
            }
            writer.Write("]}");
        }
        writer.Write("]}");
    }

    function write_config_file(file_name, config)[import {System::IO, System::Text}]
    {
        using(var writer = new ::StreamWriter(
                new ::FileStream(file_name, ::FileMode.Create, ::FileAccess.Write),
                ::Encoding.UTF8))
            write_config(writer, config);
    }

    function to_config(config)[import System::IO]
    {
        using(var writer = new ::StringWriter)
        {
            write_config(writer, config);
            return writer.ToString;
        }
    }

    function get_config(path) =
        get_test_file_names(path) >> map(tfn => tfn: read_metadata(tfn));

    function main(path)
    {
        write_config_file("testconfig.json",get_config(path));
    }

} export(main, write_config_file, get_config, to_config, write_config, 
         create_config, get_test_file_names);

function main = prx.test.make_test_configuration.main(*var args);
